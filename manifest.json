{
  "manifest_version": 3,
  "name": "CopyMailTo",
  "version": "1.0.0",
  "description": "Copies email addresses from mailto: links instead of opening your mail app.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "copymailto@umang350",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
