{
  "manifest_version": 3,
  "name": "CopyMailTo",
  "version": "1.0.0",
  "description": "Copies email addresses and phone numbers from mailto:/tel: links instead of opening your mail or phone app.",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "copymailto@umang350",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
